{
	"compilerOptions": {
		"target": "ES2018",
		"module": "ES2015",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*"]
}
