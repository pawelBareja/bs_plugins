{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bs-plugins/bs-faq",
	"version": "1.0.0",
	"title": "BS FAQ",
	"category": "design",
	"description": "Najczęściej zadawane pytania podzielone na kategorie (zakładki) z akordeonem odpowiedzi.",
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true
	},
	"attributes": {
		"kategorie": {
			"type": "array",
			"default": [
				{
					"nazwa": "Usługi",
					"pytania": [
						{ "pytanie": "Jakie usługi świadczycie?", "odpowiedz": "" },
						{ "pytanie": "Czy zajmujecie się organizacją ślubów/eventów poza Warszawą?", "odpowiedz": "" },
						{ "pytanie": "Jaki jest czas oczekiwania na odpowiedź na zapytanie ofertowe?", "odpowiedz": "" },
						{ "pytanie": "Kiedy zostanie uruchomiony sklep internetowy?", "odpowiedz": "" }
					]
				},
				{
					"nazwa": "Dostawa",
					"pytania": [ { "pytanie": "", "odpowiedz": "" } ]
				},
				{
					"nazwa": "Płatności",
					"pytania": [ { "pytanie": "", "odpowiedz": "" } ]
				},
				{
					"nazwa": "Ogólne",
					"pytania": [ { "pytanie": "", "odpowiedz": "" } ]
				}
			]
		},
		"paddingGora": { "type": "number", "default": 0 },
		"paddingDol": { "type": "number", "default": 0 },
		"paddingBoki": { "type": "number", "default": 0 },
		"kolorTlaSekcji": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"textdomain": "bs-plugins"
}
