{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bs-plugins/bs-features",
	"version": "1.0.0",
	"title": "BS Features",
	"category": "design",
	"description": "Lista cech/zalet z numerem, tytułem i opisem. Od 1 do 5 kolumn.",
	"supports": {
		"align": ["wide", "full"],
		"anchor": true
	},
	"attributes": {
		"liczbaElementow": {
			"type": "number",
			"default": 3
		},
		"elementy": {
			"type": "array",
			"default": [
				{ "numer": "01.", "tytul": "", "tresc": "" },
				{ "numer": "02.", "tytul": "", "tresc": "" },
				{ "numer": "03.", "tytul": "", "tresc": "" },
				{ "numer": "04.", "tytul": "", "tresc": "" },
				{ "numer": "05.", "tytul": "", "tresc": "" }
			]
		},
		"paddingGora": { "type": "number", "default": 0 },
		"paddingDol": { "type": "number", "default": 0 },
		"paddingBoki": { "type": "number", "default": 0 },
		"kolorTlaSekcji": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"textdomain": "bs-plugins"
}
