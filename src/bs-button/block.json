{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bs-plugins/bs-button",
	"version": "1.0.0",
	"title": "BS Button",
	"category": "design",
	"description": "Przycisk z wariantami kolorystycznymi i rozmiarami.",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"etykieta": {
			"type": "string",
			"default": ""
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"wariant": {
			"type": "string",
			"default": "bialy"
		},
		"rozmiar": {
			"type": "string",
			"default": "lg"
		},
		"nowyTab": {
			"type": "boolean",
			"default": false
		},
		"scrollOffset": {
			"type": "number",
			"default": 0
		},
		"ikonaId": { "type": "string", "default": "" },
		"ikonaSvg": { "type": "string", "default": "" },
		"ikonaPozycja": { "type": "string", "default": "start" },
		"paddingGora": { "type": "number", "default": 0 },
		"paddingDol": { "type": "number", "default": 0 },
		"paddingBoki": { "type": "number", "default": 0 },
		"kolorTlaSekcji": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"textdomain": "bs-plugins"
}
