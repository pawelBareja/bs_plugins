{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bs-plugins/bs-karty",
	"version": "1.0.0",
	"title": "BS Karty",
	"category": "design",
	"description": "Karty z obrazkiem (opcjonalna arka), tytułem, treścią i przyciskiem. Od 1 do 5 kolumn.",
	"keywords": ["karty", "oferta", "usługi", "cards"],
	"textdomain": "bs-plugins",
	"supports": {
		"align": ["wide", "full"],
		"anchor": true
	},
	"attributes": {
		"liczbaElementow": {
			"type": "number",
			"default": 3
		},
		"elementy": {
			"type": "array",
			"default": [
				{ "obrazek": null, "arkaObrazka": false, "kolorTla": "", "kolorTekstu": "", "tytul": "", "tresc": "", "przyciskEtykieta": "", "przyciskUrl": "", "przyciskWariant": "czerwony" },
				{ "obrazek": null, "arkaObrazka": false, "kolorTla": "", "kolorTekstu": "", "tytul": "", "tresc": "", "przyciskEtykieta": "", "przyciskUrl": "", "przyciskWariant": "czerwony" },
				{ "obrazek": null, "arkaObrazka": false, "kolorTla": "", "kolorTekstu": "", "tytul": "", "tresc": "", "przyciskEtykieta": "", "przyciskUrl": "", "przyciskWariant": "czerwony" },
				{ "obrazek": null, "arkaObrazka": false, "kolorTla": "", "kolorTekstu": "", "tytul": "", "tresc": "", "przyciskEtykieta": "", "przyciskUrl": "", "przyciskWariant": "czerwony" },
				{ "obrazek": null, "arkaObrazka": false, "kolorTla": "", "kolorTekstu": "", "tytul": "", "tresc": "", "przyciskEtykieta": "", "przyciskUrl": "", "przyciskWariant": "czerwony" }
			]
		},
		"paddingGora": { "type": "number", "default": 0 },
		"paddingDol": { "type": "number", "default": 0 },
		"paddingBoki": { "type": "number", "default": 0 },
		"kolorTlaSekcji": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
